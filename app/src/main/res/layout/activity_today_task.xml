<?xml version="1.0" encoding="utf-8"?>


<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/dateTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <TextView
        android:id="@+id/tasksCountTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tasksRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id= "@+id/emptyTasksTextView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/btnGoToCreateTask"
        android:layout_width="match_parent"
        android:layout_height= "wrap_content"
        android:text="Добавить задачу" />

    <Button
        android:id="@+id/btnShowAllTasks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Показать все задачи" />


    <Button
        android:id="@+id/btnBackToMain"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="На главный экран" />

    <Button

        android:id ="@+id/btnDebug"
        android:layout_width ="match_parent"
        android:layout_height="wrap_content"
        android:text="Отладка" />



</LinearLayout>